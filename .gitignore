# ===========================================================================
# STRATUM PROTOCOL — .gitignore
# ===========================================================================

# Environment / Secrets
.env
.env.local
.env.*.local
*.pem
*.key
*.p12
secrets/

# Node
node_modules/
frontend/node_modules/
services/websocket-gateway/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Frontend build output
frontend/dist/
frontend/.vite/

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.eggs/
.venv/
venv/
env/
*.egg
pip-wheel-metadata/
.mypy_cache/
.ruff_cache/

# Testing
.pytest_cache/
.coverage
htmlcov/
coverage.xml
*.log

# Docker volumes / local data
data/
volumes/
docker-data/

# Terraform
*.tfstate
*.tfstate.backup
.terraform/
.terraform.lock.hcl

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Kubernetes secrets (never commit these)
infra/k8s/secrets.yaml
infra/k8s/*-secret.yaml
infra/helm/**/secrets.yaml

# Compiled protobuf
*_pb2.py
*_pb2_grpc.py

# Jupyter
.ipynb_checkpoints/

# Model artifacts (large binary files)
*.pt
*.pth
*.onnx
*.pkl
models/
checkpoints/

# Logs
logs/
*.log
frontend/node_modules/
