# =============================================================================
# STRATUM PROTOCOL — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# PLATFORM
# ---------------------------------------------------------------------------
STRATUM_ENV=development       # development | staging | production
STRATUM_VERSION=1.0.0
LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# KAFKA
# ---------------------------------------------------------------------------
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_SECURITY_PROTOCOL=PLAINTEXT   # PLAINTEXT | SSL | SASL_SSL
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=
KAFKA_SCHEMA_REGISTRY_URL=http://localhost:8081

# ---------------------------------------------------------------------------
# NEO4J (Knowledge Graph)
# ---------------------------------------------------------------------------
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=stratum_neo4j_secret
NEO4J_DATABASE=stratumgraph

# ---------------------------------------------------------------------------
# POSTGRESQL (Transactional)
# ---------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=stratum_db
POSTGRES_USER=stratum
POSTGRES_PASSWORD=stratum_pg_secret
DATABASE_URL=postgresql+asyncpg://stratum:stratum_pg_secret@localhost:5432/stratum_db

# ---------------------------------------------------------------------------
# TIMESCALEDB (Time-Series)
# ---------------------------------------------------------------------------
TIMESCALE_HOST=localhost
TIMESCALE_PORT=5433
TIMESCALE_DB=stratum_timeseries
TIMESCALE_USER=stratum_ts
TIMESCALE_PASSWORD=stratum_ts_secret
TIMESCALE_URL=postgresql+asyncpg://stratum_ts:stratum_ts_secret@localhost:5433/stratum_timeseries

# ---------------------------------------------------------------------------
# REDIS (Cache)
# ---------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=stratum_redis_secret
REDIS_MAX_CONNECTIONS=100

# ---------------------------------------------------------------------------
# S3-COMPATIBLE OBJECT STORAGE
# ---------------------------------------------------------------------------
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_MODELS=stratum-models
S3_BUCKET_REPORTS=stratum-reports

# ---------------------------------------------------------------------------
# HASHICORP VAULT
# ---------------------------------------------------------------------------
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=root-dev-token
VAULT_MOUNT_PATH=stratum

# ---------------------------------------------------------------------------
# JWT / AUTH
# ---------------------------------------------------------------------------
JWT_SECRET_KEY=CHANGE_ME_IN_PRODUCTION_USE_256BIT_KEY
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
OAUTH2_CLIENT_ID=stratum-ui
OAUTH2_CLIENT_SECRET=CHANGE_ME_OAUTH2_SECRET

# ---------------------------------------------------------------------------
# MAPBOX (Frontend)
# ---------------------------------------------------------------------------
VITE_MAPBOX_ACCESS_TOKEN=pk.your_mapbox_token_here

# ---------------------------------------------------------------------------
# SERVICE DISCOVERY
# ---------------------------------------------------------------------------
DATA_INGESTION_URL=http://localhost:8001
KNOWLEDGE_GRAPH_URL=http://localhost:8002
STATE_ESTIMATION_URL=http://localhost:8003
CASCADE_FAILURE_URL=http://localhost:8004
CITIZEN_BEHAVIOR_URL=http://localhost:8005
POLICY_SIMULATION_URL=http://localhost:8006
CAPITAL_OPTIMIZATION_URL=http://localhost:8007
DECISION_LEDGER_URL=http://localhost:8008
FEDERATED_LEARNING_URL=http://localhost:8009
GOVERNANCE_URL=http://localhost:8010
CYBER_DEFENSE_URL=http://localhost:8011
ORCHESTRATION_URL=http://localhost:8012
URBAN_EVOLUTION_URL=http://localhost:8013
AUTH_SERVICE_URL=http://localhost:8000
WEBSOCKET_GATEWAY_URL=ws://localhost:9000

# ---------------------------------------------------------------------------
# GPU / ROCM
# ---------------------------------------------------------------------------
ROCM_VISIBLE_DEVICES=0,1,2,3
PYTORCH_HIP_ALLOC_CONF=max_split_size_mb:512
CUDA_VISIBLE_DEVICES=   # Leave empty if using ROCm

# ---------------------------------------------------------------------------
# FEDERATED LEARNING
# ---------------------------------------------------------------------------
FL_SERVER_HOST=0.0.0.0
FL_SERVER_PORT=8080
FL_ROUNDS=10
FL_MIN_CLIENTS=3
FL_DP_EPSILON=0.1
FL_DP_DELTA=1e-5
FL_DP_MAX_GRAD_NORM=1.0

# ---------------------------------------------------------------------------
# OBSERVABILITY
# ---------------------------------------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
PROMETHEUS_MULTIPROC_DIR=/tmp/prometheus_multiproc
JAEGER_AGENT_HOST=localhost
JAEGER_AGENT_PORT=6831
